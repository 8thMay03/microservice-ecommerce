# Copy to ".env" in this folder and fill in values. Docker Compose reads .env for ${VAR} substitution.

# Google AI (Gemini) — required for rag-service embeddings / chat
GOOGLE_API_KEY=
OPENAI_API_KEY=
AI_PROVIDER=gemini # Or openai

# Neo4j (docker-compose neo4j + graph-rag-service). Default matches compose fallback.
NEO4J_PASSWORD=
